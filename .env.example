# Servidor
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/gmail_sender

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Segurança – chave para autenticar requisições à API (opcional)
API_SECRET_KEY=sua_chave_secreta_aqui

# Criptografia das App Passwords no banco
CRYPT_SECRET=troque_por_segredo_de_32_chars_aqui
