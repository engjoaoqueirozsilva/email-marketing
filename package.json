{
  "name": "gmail-sender-api",
  "version": "2.0.0",
  "description": "API REST para envio de emails via Gmail com Nodemailer + MongoDB",
  "main": "src/server.js",
  "scripts": {
    "start": "cross-env NODE_ENV=development node src/server.js",
    "start:prod": "cross-env NODE_ENV=production  node src/server.js",
    "dev": "cross-env NODE_ENV=development nodemon src/server.js",
    "test": "jest --coverage"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "http-status-codes": "^2.3.0",
    "joi": "^17.12.2",
    "mongoose": "^8.3.4",
    "nodemailer": "^8.0.2",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
